{
  "manifest_version": 3,
  "name": "All In One",
  "version": "1.04",
  "description": "Ultimativni alat koji spaja sve bitne funkcije u jedan brz, moderan i besplatan interfejs.",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "idle",
    "offscreen",
    "browsingData"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "yt.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "commands": {
    "mark-lap": {
      "suggested_key": {
        "default": "Alt+Shift+L"
      },
      "description": "Zabeleži trenutak za klip"
    }
  }
}